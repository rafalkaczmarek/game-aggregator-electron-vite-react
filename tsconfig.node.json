{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "verbatimModuleSyntax": true,
    "types": ["node"],
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "paths": {
      "@shared/*": ["./shared/*"]
    }
  },
  "include": ["electron", "shared", "vite.config.ts", "vitest.config.ts", "playwright.config.ts", "package.json"]
}
